<li
    class="step-item {{ first ? 'active' : '' }}"
    data-testid="history-event"
    {# If the item doesn't have any versions, the creation event will be used instead #}
    {% if is_curent_version or is_creation_event %}
        data-glpi-current-version
    {% elseif is_current_translation %}
        data-glpi-current-translation-language="{{ event.getLanguage() }}"
    {% elseif is_translation_revision %}
        data-glpi-translation-revision-id="{{ event.getRevisionId() }}"
        data-glpi-translation-revision-language="{{ event.getLanguage() }}"
        data-glpi-kb-id="{{ id }}"
    {% elseif is_revision %}
        data-glpi-revision-id="{{ event.getRevisionId() }}"
        data-glpi-kb-id="{{ id }}"
    {% endif %}
>
    <div class="d-flex align-items-start justify-content-between">
        <div>
            <div class="h4 m-0">
                {{ event.getLabel() }}
            </div>
            <div class="text-secondary small">
                <span
                    {% if is_log and (event.getOldValue() is not null or event.getNewValue() is not null) %}
                        {% set tooltip_parts = [] %}
                        {% if event.getOldValue() is not null %}
                            {% set tooltip_parts = tooltip_parts|merge([__('Before: %s')|format(event.getOldValue())]) %}
                        {% endif %}
                        {% if event.getNewValue() is not null %}
                            {% set tooltip_parts = tooltip_parts|merge([__('After: %s')|format(event.getNewValue())]) %}
                        {% endif %}

                        data-bs-toggle="tooltip"
                        data-bs-placement="bottom"
                        title="{{ tooltip_parts|join(' → ') }}"
                    {% endif %}
                >
                    {{ event.getDescription() }}
                </span>

                {% set user = users.getUser(event.getAuthor()) %}
                {% if user %}
                    <a rel="author" href="{{ user.getLinkUrl() }}" class="badge bg-azure-lt ms-1">
                        @{{ user.getFriendlyName() }}
                    </a>
                {% else %}
                    <span class="badge bg-secondary-lt ms-1">{{ __("Deleted user") }}</span>
                {% endif %}
            </div>
            <div class="text-secondary small">
                <span
                    title="{{ event.date }}"
                    data-bs-toggle="tooltip"
                    data-bs-placement="bottom"
                >
                    {{ event.date|relative_datetime }}
                </span>
            </div>
        </div>
        {% if is_translation_revision and can_revert %}
            <button
                type="button"
                class="btn btn-ghost-secondary btn-sm"
                data-glpi-revert-translation-revision="{{ event.getRevisionId() }}"
                data-glpi-translation-revision-language="{{ event.getLanguage() }}"
                data-glpi-kb-id="{{ id }}"
                title="{{ __("Restore this translation version") }}"
                data-bs-toggle="tooltip"
                data-bs-placement="left"
            >
                <i class="ti ti-restore"></i>
            </button>
        {% elseif is_revision and can_revert %}
            <button
                type="button"
                class="btn btn-ghost-secondary btn-sm"
                data-glpi-revert-revision="{{ event.getRevisionId() }}"
                data-glpi-kb-id="{{ id }}"
                title="{{ __("Restore this version") }}"
                data-bs-toggle="tooltip"
                data-bs-placement="left"
            >
                <i class="ti ti-restore"></i>
            </button>
        {% endif %}
    </div>
</li>
