<div class="card card-sm mb-2" data-glpi-kb-category-edit-form data-glpi-kb-category-id="{{ id }}">
    <div class="card-body">
        <div class="mb-2">
            {{ include('components/illustration/icon_picker.html.twig', {
                name: 'illustration',
                value: illustration,
                size: 40,
            }, with_context: false) }}
        </div>
        <div class="mb-2">
            <label class="form-label" for="kb-category-comment-{{ id }}">{{ __('Comment') }}</label>
            <textarea
                id="kb-category-comment-{{ id }}"
                class="form-control"
                rows="2"
                data-glpi-kb-category-edit-comment
            >{{ comment }}</textarea>
        </div>
        <div class="alert alert-danger d-none" role="alert" data-glpi-kb-category-edit-error></div>
        <div class="d-flex justify-content-end">
            <button
                type="button"
                class="btn btn-ghost-secondary me-2"
                data-glpi-kb-category-edit-cancel
            >{{ __('Cancel') }}</button>
            <button
                type="button"
                class="btn btn-primary"
                data-glpi-kb-category-edit-save
            >{{ __('Save') }}</button>
        </div>
    </div>
</div>
