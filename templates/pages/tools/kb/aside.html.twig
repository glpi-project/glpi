{% macro render_category(category, can_create = false, can_create_category = false, category_form_url = '') %}
    {% import _self as macros %}
    <li class="node" data-glpi-kb-aside-category role="group" aria-label="{{ category.title }}">
        <div class="d-flex align-items-center mb-2" data-glpi-kb-aside-category-header>
            <button
                type="button"
                class="d-flex align-items-center p-0 flex-grow-1 text-start border-0 bg-transparent"
                data-glpi-kb-aside-category-toggle
                aria-label="{{ category.title }}"
                aria-expanded="true"
            >
                <i class="ti ti-chevron-down me-1 fs-4" aria-hidden="true"></i>
                {% if category.illustration %}
                    {{ render_illustration(category.illustration, 20) }}
                {% endif %}
                <span class="ms-2 fw-bold text-truncate d-block">{{ category.title }}</span>
            </button>
            {% if can_create %}
                {% set add_href = category.id > 0 ? path('glpi_knowbaseitem_form_central', {knowbaseitemcategories_id: category.id}) : path('glpi_knowbaseitem_form_central') %}
                {% set add_title = category.id > 0 ? __('Create an article in this category') : __('Create an uncategorized article') %}
                <a
                    href="{{ add_href }}"
                    class="d-flex align-items-center ms-2 p-1 text-secondary"
                    data-glpi-kb-aside-category-add
                    aria-label="{{ __('Create an article in %s')|format(category.title) }}"
                    title="{{ add_title }}"
                >
                    <i class="ti ti-plus" aria-hidden="true"></i>
                </a>
            {% endif %}
            {% if can_create_category and category.id > 0 %}
                <a
                    href="{{ category_form_url }}?knowbaseitemcategories_id={{ category.id }}"
                    class="d-flex align-items-center ms-1 p-1 text-secondary"
                    data-glpi-kb-aside-category-create
                    aria-label="{{ __('Create a sub-category in %s')|format(category.title) }}"
                    title="{{ __('Create a sub-category in this category') }}"
                >
                    <i class="ti ti-folder-plus" aria-hidden="true"></i>
                </a>
            {% endif %}
        </div>
        <ul>
            {{ macros.render_node(category, can_create, can_create_category, category_form_url) }}
        </ul>
    </li>
{% endmacro %}

{% macro render_article(article, add_margin = false, favorite_state = null) %}
    <li
        data-glpi-kb-article-id="{{ article.id }}"
        {% if favorite_state is not null %}
            data-glpi-kb-favorite-current="{{ favorite_state }}"
        {% endif %}
        {% if article.is_current %}
            data-glpi-kb-article-current
            aria-current="page"
        {% endif %}
        class="article {{ add_margin ? 'mb-2' : '' }}"
    >
        <a class="text-dark text-hover-link text-truncate d-block" href="{{ article.link }}">
            {% if article.illustration %}
                {{ render_illustration(article.illustration, 20) }}
            {% endif %}
            {{ article.title }}
        </a>
    </li>
{% endmacro %}

{% macro render_node(node, can_create = false, can_create_category = false, category_form_url = '') %}
    {% import _self as macros %}
    {% for article in node.articles %}
        {{ macros.render_article(article) }}
    {% endfor %}
    {% for category in node.categories %}
        {{ macros.render_category(category, can_create, can_create_category, category_form_url) }}
    {% endfor %}
{% endmacro %}

{% import _self as macros %}

{% set hide_favorites = not has_other_favorites and not current_is_favorite %}

<div class="card-header flex-column align-items-start" data-glpi-kb-aside-header {{ hide_favorites ? 'data-glpi-kb-aside-header-no-border' : '' }}>
    <h3 class="card-title fw-bold mb-3">{{ __("Articles") }}</h3>

    <div class="input-icon mb-2">
        <input
            type="text"
            value=""
            class="form-control pe-none"
            placeholder="{{ __('Search...') }}"
            aria-label="{{ __('Search articles') }}"
            data-glpi-kb-aside-search-input
        >
        <button
            class="input-icon-addon border-0 bg-transparent"
            data-glpi-kb-aside-search-clear
            disabled="true"
            aria-label="{{ __('Clear search') }}"
        >
            <span class="ti ti-search" data-glpi-kb-aside-search-icon></span>
        </button>
    </div>
</div>

<div
    class="card-body flex-grow-0"
    data-glpi-kb-aside-favorites
    data-testid="kb-aside-favorites"
    {{ hide_favorites ? 'data-glpi-kb-aside-favorites-hidden' : '' }}
>
    <h4 class="card-title fw-bold fs-4">
        <i class="ti ti-star-filled me-1 fs-5 text-yellow"></i>
        {{ __("Favorites") }}
    </h4>
        <ul class="kb-tree ps-0">
            {% for article in favorites %}
                {% if article.is_current %}
                    {{ macros.render_article(
                        article,
                        true,
                        current_is_favorite ? 'active' : 'pending',
                    ) }}
                {% else %}
                    {{ macros.render_article(article, true) }}
                {% endif %}
            {% endfor %}
        </ul>
</div>

<div class="card-body" data-glpi-kb-aside-tree>
    <ul class="kb-tree ps-0">
        {# Render root articles in a special "uncategorized" category #}
        {% if tree.articles|length or can_create %}
            {{ macros.render_category({
                id: 0,
                title: __("Uncategorized"),
                illustration: "",
                articles: tree.articles,
                categories: [],
            }, can_create, false, category_form_url) }}
        {% endif %}

        {# Render each categories #}
        {% for category in tree.categories %}
            {{ macros.render_category(category, can_create, can_create_category, category_form_url) }}
        {% endfor %}
    </ul>
    <p class="text-muted" data-glpi-kb-aside-no-results hidden>
        {{ __("No articles found.") }}
    </p>
</div>

<script type="module">
    (async () => {
        const { GlpiKnowbaseAsideController } = await import(
            "/js/modules/Knowbase/AsideController.js"
        );
        const aside = document.querySelector('[data-main-page-aside="knowbaseitem"]');
        new GlpiKnowbaseAsideController(aside);
    })();
</script>

