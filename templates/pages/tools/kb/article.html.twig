<div class="d-flex mx-n2 my-n2" data-glpi-knowbase-article>
    <article class="col-9 container ms-0 px-4 py-3 kb-article">
        <div class="d-flex align-items-center mb-3">
            <h1 class="fw-bold mb-0" data-testid="subject">{{ subject }}</h1>
            <div class="ms-auto d-flex align-items-center gap-2">
                {# Edit/Save/Cancel buttons #}
                {% if can_edit %}
                    <div class="kb-editor-actions d-flex gap-2">
                        <button type="button"
                                class="btn btn-outline-secondary"
                                data-action="toggle-edit"
                                data-testid="edit-button">
                            <i class="ti ti-edit me-1"></i>{{ __('Edit') }}
                        </button>
                        <button type="button"
                                class="btn btn-primary d-none"
                                data-action="save"
                                data-testid="save-button">
                            <i class="ti ti-device-floppy me-1"></i>{{ __('Save') }}
                        </button>
                        <button type="button"
                                class="btn btn-outline-secondary d-none"
                                data-action="cancel"
                                data-testid="cancel-button">
                            {{ __('Cancel') }}
                        </button>
                    </div>
                {% endif %}

                {# Actions dropdown #}
                <div class="dropdown cursor-pointer d-flex align-items-center">
                    {% if edit_mode and actions|length > 0 %}
                        <i
                            class="ti ti-dots-vertical"
                            data-bs-toggle="dropdown"
                            aria-expanded="false"
                            role="button"
                            title="{{ __('More actions') }}"
                        ></i>
                        <ul class="dropdown-menu" data-bs-popper="none">
                            {% for action in actions %}
                                <li>
                                    <button
                                        type="button"
                                        class="dropdown-item"
                                        aria-label="{{ action.label }}"
                                        data-glpi-kb-action="{{ action.type.value }}"
                                        {% for key, param in action.params %}
                                            data-glpi-kb-action-param-{{ key }}="{{ param }}"
                                        {% endfor %}
                                    >
                                        <i class="{{ action.icon }}"></i>
                                        <span>{{ action.label }}</span>
                                    </button>
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="text-muted d-flex align-items-center gap-3">
            {# Last update #}
            <div class="d-flex align-items-center" data-testid="last-update">
                <i class="ti ti-clock me-1 fs-3"></i>
                <span>
                    <span>{{ __("Updated:") }}</span>
                    <time
                        title="{{ last_update_date }}"
                        data-bs-toggle="tooltip"
                        data-bs-placement="bottom"
                    >{{ last_update_relative_date }}</time>
                    <span>{{ __("by") }}</span>
                </span>
                <address class="mb-0">
                    {% if last_update_author_link is not null and last_update_can_view_author %}
                        <a
                            rel="author"
                            href="{{ last_update_author_link }}"
                            class="badge bg-azure-lt ms-1"
                            data-testid="author_link"
                        >
                            @{{ last_update_author_name }}
                        </a>
                    {% else %}
                        <span class="badge bg-dark-lt ms-1">
                            @{{ last_update_author_name }}
                        </span>
                    {% endif %}
                </address>
            </div>

            {# Views #}
            <div class="d-flex align-items-center">
                <i class="ti ti-eye me-1 fs-3"></i>
                <span data-testid="views">
                    {% if views == 0 %}
                        {{ __("No views") }}
                    {% else %}
                        {{ _n("%s view", "%s views", views)|format(views|formatted_integer) }}
                    {% endif %}
                </span>
            </div>
        </div>

        <hr class="mt-4 mb-4">

        {# Tiptap editor container #}
        <div id="kb-tiptap-editor"
             class="rich_text_container"
             data-testid="content">
            {{ answer|safe_html }}
        </div>
    </article>
    <div
        class="col-3 container kb-sidepanel px-4 py-3 d-none d-flex flex-column"
        data-glpi-knowbase-side-panel
    >
    </div>
</div>

<script type="module">
    (async () => {
        const module = await import(
            "{{ js_path('js/modules/Knowbase/ArticleController.js') }}"
        );
        new module.GlpiKnowbaseArticleController(
            document.querySelector('[data-glpi-knowbase-article]'),
            document.querySelector('[data-glpi-knowbase-side-panel]'),
        );
    })();
</script>

{% if can_edit %}
<script>
(function() {
    // Execute immediately - this template is loaded via AJAX so DOM is already ready
    const editorElement = document.getElementById('kb-tiptap-editor');
    const editButton = document.querySelector('[data-action="toggle-edit"]');
    const saveButton = document.querySelector('[data-action="save"]');
    const cancelButton = document.querySelector('[data-action="cancel"]');

    if (!editorElement || !editButton || !window.KnowbaseEditor) {
        return;
    }

    // Store original content for cancel functionality
    const originalContent = editorElement.innerHTML;
    let editor = null;

    // Initialize editor in readonly mode
    editor = new window.KnowbaseEditor(editorElement, {
        content: originalContent,
        readonly: true,
        placeholder: '{{ __("Start writing...")|e('js') }}',
        onUpdate: function(html) {
            // Content updated
        }
    });

    // Toggle edit mode
    editButton.addEventListener('click', function() {
        editor.setEditable(true);
        editor.focus();
        editButton.classList.add('d-none');
        saveButton.classList.remove('d-none');
        cancelButton.classList.remove('d-none');
    });

    // Cancel editing
    cancelButton.addEventListener('click', function() {
        editor.setContent(originalContent);
        editor.setEditable(false);
        editButton.classList.remove('d-none');
        saveButton.classList.add('d-none');
        cancelButton.classList.add('d-none');
    });

    // Save content
    saveButton.addEventListener('click', async function() {
        saveButton.disabled = true;
        saveButton.innerHTML = '<i class="ti ti-loader me-1"></i>{{ __("Saving...")|e('js') }}';

        try {
            const response = await fetch(CFG_GLPI.root_doc + '/Knowbase/KnowbaseItem/{{ item_id }}/Answer', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest',
                    'X-Glpi-Csrf-Token': getAjaxCsrfToken(),
                },
                body: JSON.stringify({
                    answer: editor.getHTML(),
                }),
            });

            const result = await response.json();

            if (result.success) {
                // Update original content for future cancel operations
                const newContent = editor.getHTML();
                editor.setEditable(false);
                editButton.classList.remove('d-none');
                saveButton.classList.add('d-none');
                cancelButton.classList.add('d-none');

                // Show success notification
                if (typeof glpi_toast_info === 'function') {
                    glpi_toast_info('{{ __("Article saved successfully")|e('js') }}');
                }
            } else {
                throw new Error(result.message || '{{ __("Failed to save")|e('js') }}');
            }
        } catch (error) {
            if (typeof glpi_toast_error === 'function') {
                glpi_toast_error(error.message || '{{ __("An error occurred while saving")|e('js') }}');
            }
        } finally {
            saveButton.disabled = false;
            saveButton.innerHTML = '<i class="ti ti-device-floppy me-1"></i>{{ __("Save")|e('js') }}';
        }
    });
})();
</script>
{% endif %}
