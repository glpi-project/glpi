{# Tab navigation - moved into modal header by script below #}
<div data-glpi-targets-nav>
    <ul class="nav nav-underline kb-modal-nav flex-fill mb-0" role="tablist">
        <li class="nav-item" role="presentation">
            <button
                class="nav-link active"
                data-bs-toggle="tab"
                data-bs-target="#targets-permissions-{{ id }}"
                type="button"
                role="tab"
            >
                <i class="ti ti-lock me-1"></i>{{ __('Permissions') }}
            </button>
        </li>
        {% if can_edit %}
            <li class="nav-item" role="presentation">
                <button
                    class="nav-link"
                    data-bs-toggle="tab"
                    data-bs-target="#targets-sharing-{{ id }}"
                    type="button"
                    role="tab"
                >
                    <i class="ti ti-share me-1"></i>{{ __('Sharing') }}
                </button>
            </li>
        {% endif %}
    </ul>
</div>

<div class="tab-content mt-3">
    <div class="tab-pane active" id="targets-permissions-{{ id }}" role="tabpanel">
        {% include 'pages/tools/kb/modal/permissions.html.twig' with permissions only %}
    </div>
    {% if can_edit %}
        <div class="tab-pane" id="targets-sharing-{{ id }}" role="tabpanel">
            {% include 'pages/tools/kb/modal/sharing.html.twig' with sharing only %}
        </div>
    {% endif %}
</div>

<script type="module">
    import { GlpiKnowbaseTargetsModalController } from "/js/modules/Knowbase/TargetsModalController.js";
    import { GlpiKnowbaseSharingPanelController } from "/js/modules/Knowbase/SharingPanelController.js";
    new GlpiKnowbaseTargetsModalController();
    const sharingPanel = document.querySelector('[data-glpi-sharing-panel]');
    if (sharingPanel) {
        new GlpiKnowbaseSharingPanelController(sharingPanel);
    }
</script>
