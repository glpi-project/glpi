{% set has_entries = entries|length > 0 %}

{# Status label #}
<h3 class="mb-2 fs-4" data-testid="permissions-status">
    {{ __('Can be viewed by:') }}
</h3>

{# Permissions list #}
<ul class="list-group list-group-flush" data-testid="permissions-list" data-glpi-permissions-list>
    {% if not has_entries %}
        <div class="text-secondary py-1" data-testid="empty-permissions">
            {{ __('This article is not yet visible to anyone.') }}
        </div>
    {% endif %}

    {% for entry in entries %}
        <li class="list-group-item d-flex align-items-center gap-2 py-2 px-0 border-0"
            data-testid="permission-entry"
            data-glpi-permission-id="{{ entry.id }}"
            data-glpi-permission-itemtype="{{ entry.itemtype }}"
        >

            {# Avatar: user picture for Users, typed icon for others #}
            {% if entry.type == 'User' %}
                {{ include('components/user/picture.html.twig', {
                    users_id: entry.users_id,
                    avatar_size: 'avatar-sm',
                    with_link: false,
                    enable_anonymization: false,
                }) }}
            {% else %}
                <span
                    class="avatar avatar-sm rounded {{ entry.badge_class }}"
                    title="{{ entry.type|itemtype_name }}"
                    data-bs-toggle="tooltip"
                    data-bs-placement="left"
                >
                    <i class="ti {{ entry.icon }}"></i>
                </span>
            {% endif %}

            {# Info #}
            <div class="flex-grow-1" style="min-width: 0;">
                <div class="d-flex align-items-center gap-1" data-testid="entry-label">
                    <span class="fw-medium text-truncate">{{ entry.name }}</span>
                    {% if entry.type == "Entity" and entry.is_recursive %}
                        <span class="text-secondary">({{ __("recursive") }})</span>
                    {% endif %}
                </div>
                {% if entry.entity_name and (entry.entities_id != 0 or entry.is_recursive != 1) %}
                    <div class="text-secondary small text-truncate" data-testid="entry-context">
                        {{ entry.entity_name }}
                        {% if entry.type != "Entity" and entry.is_recursive %}
                            <span>({{ __("recursive") }})</span>
                        {% endif %}
                    </div>
                {% endif %}
            </div>

            {# Delete button #}
            {% if can_edit %}
                <button type="button"
                    class="btn btn-ghost-danger btn-sm btn-icon ms-auto"
                    data-glpi-permission-delete
                    title="{{ __('Delete') }}"
                    data-bs-toggle="tooltip"
                >
                    <i class="ti ti-trash"></i>
                </button>
            {% endif %}
        </li>
    {% endfor %}
</ul>

{# Add target form #}
{% if can_edit %}
    <div class="mt-4">
        <form method="post" action="{{ 'KnowbaseItem'|itemtype_form_path }}">
            <input type="hidden" name="knowbaseitems_id" value="{{ id }}">
            {% set add_label = __('Add access for') %}
            <div class="row g-3" id="kb-permissions-form-{{ rand }}" data-testid="publish-form">
                {# Row 1: type + item dropdowns + Entity child entities inline #}
                <div class="col-12">
                    <div class="row g-2 align-items-end">
                        <div class="col">
                            <label class="form-label">{{ add_label }}</label>
                            <div class="input-group">
                                <div class="flex-grow-1 visibility-type-col" id="visibility-type-col{{ rand }}">
                                    {% do call('Dropdown::showItemTypes', ['_type', ['Entity', 'Group', 'Profile', 'User'], {
                                        'rand': rand,
                                        'value': '',
                                        'emptylabel': __('Select a type...'),
                                        'aria_label': add_label,
                                        'width': '100%',
                                    }]) %}
                                </div>
                                <div class="flex-grow-30 d-none visibility-item-col" id="visibility{{ rand }}" style="min-width: 0; flex-basis: 0;"></div>
                            </div>
                        </div>
                        <div class="col-auto d-none" id="visibility-recursive{{ rand }}" data-testid="child-entities-label">
                            <label
                                class="form-label"
                                for="dropdown_is_recursive{{ rand }}"
                            >{{ __('Child entities') }}</label>
                            {% do call('Dropdown::showYesNo', ['is_recursive', 1, -1, {
                                rand: rand,
                            }]) %}
                        </div>
                    </div>
                </div>
                {# Advanced options #}
                <div id="visibility-advanced{{ rand }}" class="col-12 d-none">
                    <div id="visibility-advanced-content{{ rand }}" class="row g-3 kb-permission-visibility" data-testid="advanced-content"></div>
                </div>
                {# Toggle + Submit #}
                <div class="col-12 d-flex justify-content-between align-items-center">
                    <button type="button"
                        id="visibility-advanced-toggle{{ rand }}"
                        class="btn btn-sm btn-link text-start p-0 d-none"
                    >
                        <i class="ti ti-settings me-1"></i>{{ __('Show advanced options') }}
                    </button>
                    <div class="ms-auto">
                        <button type="submit"
                                id="visibility-submit-btn{{ rand }}"
                                name="addvisibility"
                                class="btn btn-primary d-none">
                            <i class="ti ti-plus me-1"></i>{{ _x('button', 'Add') }}
                        </button>
                    </div>
                </div>
            </div>
            <script type="module">
                (async () => {
                    const { GlpiKnowbasePermissionsFormController } = await import(
                        "{{ js_path('js/modules/Knowbase/PermissionsFormController.js') }}"
                    );
                    new GlpiKnowbasePermissionsFormController(
                        document.getElementById('kb-permissions-form-{{ rand|e('js') }}'),
                        '{{ rand|e('js') }}',
                        {{ visiblity_dropdown_params|json_encode|raw }},
                    );
                })();
            </script>
        </form>
    </div>
{% endif %}

{% if can_edit %}
<script>
    (() => {
        const list = document.querySelector('[data-glpi-permissions-list]');
        if (!list) {
            return;
        }

        list.addEventListener('click', async (e) => {
            const btn = e.target.closest('[data-glpi-permission-delete]');
            if (!btn) {
                return;
            }

            const row = btn.closest('[data-glpi-permission-id]');
            const permission_id = row.dataset.glpiPermissionId;
            const itemtype = row.dataset.glpiPermissionItemtype;

            {% if not is_owner %}
                const confirmed = await glpi_confirm_danger({
                    title: '{{ __("Delete target")|e("js") }}',
                    message: '{{ __("Caution! You are not the author of this item. Deleting targets can result in loss of access.")|e("js") }}',
                    confirm_label: '{{ __("Delete")|e("js") }}',
                });
                if (!confirmed) {
                    return;
                }
            {% endif %}

            try {
                const response = await fetch(
                    `${CFG_GLPI.root_doc}/Knowbase/KnowbaseItem/Permission/${itemtype}/${permission_id}`,
                    {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest',
                        },
                    }
                );

                if (!response.ok) {
                    throw new Error();
                }

                row.remove();
            } catch {
                glpi_toast_error('{{ __("An error occurred while deleting the permission.")|e("js") }}');
            }
        });
    })();
</script>
{% endif %}
