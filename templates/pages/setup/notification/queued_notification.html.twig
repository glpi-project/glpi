{% extends 'generic_show_form.html.twig' %}
{% import 'components/form/fields_macros.html.twig' as fields %}

{% block form_fields %}
    {{ fields.htmlField('', (parent != null ? get_class(parent) : constant('NOT_AVAILABLE'))|e, _n('Type', 'Types', 1)) }}
    {% if parent is instanceof('CommonDBTM') %}
        {{ fields.htmlField('', parent != null ? parent.getLink() : constant('NOT_AVAILABLE')|e, _n('Item', 'Items', 1)) }}
    {% else %}
        {{ fields.nullField() }}
    {% endif %}

    {{ fields.htmlField('', get_item_name('NotificationTemplate', item.fields['notificationtemplates_id'])|e, 'NotificationTemplate'|itemtype_name) }}
    {{ fields.nullField() }}

    {{ fields.htmlField('', item.fields['create_time']|e, __('Creation date')) }}
    {{ fields.htmlField('', item.fields['send_time']|e, __('Expected send date')) }}
    {{ fields.htmlField('', item.fields['sent_time']|e, __('Send date')) }}
    {{ fields.htmlField('', item.fields['sent_try']|e, __('Number of tries of sent')) }}

    {{ fields.smallTitle(_n('Email', 'Emails', 1)) }}
    {{ fields.htmlField('', item.fields['sender']|e, __('Sender email')) }}
    {{ fields.htmlField('', item.fields['sendername']|e, __('Sender name')) }}
    {{ fields.htmlField('', item.fields['recipient']|e, __('Recipient email')) }}
    {{ fields.htmlField('', item.fields['recipientname']|e, __('Recipient name')) }}
    {{ fields.htmlField('', item.fields['replyto']|e, __('Reply-To email')) }}
    {{ fields.htmlField('', item.fields['replytoname']|e, __('Reply-To name')) }}
    {{ fields.htmlField('', item.fields['messageid']|e, __('Message ID')) }}
    {{ fields.htmlField('', additional_headers|e, __('Additional headers')) }}
    {{ fields.htmlField('', item.fields['name']|e, __('Subject')) }}

    {{ fields.smallTitle(__('Content')) }}
    {% set has_html_content = item.fields['body_html'] is not empty %}
    <div class="row">
        <div class="col-xxl-12">
            <ul class="nav nav-tabs" id="emailBodyTabs" role="tablist">
                {% if has_html_content %}
                    <li class="nav-item">
                        <a class="nav-link active" id="html-tab" data-bs-toggle="tab" href="#html" role="tab" aria-controls="html" aria-selected="false">{{ __('HTML') }}</a>
                    </li>
                {% endif %}
                <li class="nav-item">
                    <a class="nav-link {{ has_html_content ? '' : 'active' }}" id="text-tab" data-bs-toggle="tab" href="#text" role="tab" aria-controls="text" aria-selected="true">{{ __('Text') }}</a>
                </li>
            </ul>
            <div class="tab-content" id="emailBodyTabsContent">
                {% if has_html_content %}
                <div class="tab-pane fade show active" id="html" role="tabpanel" aria-labelledby="html-tab">
                    {% set body_html = item.cleanHtml(item.fields['body_html'])|safe_html %}
                    {% if undisclose_body %}
                        {% set body_html = __('The content of the notification contains sensitive information and therefore cannot be displayed.')|e %}
                    {% endif %}
                    {{ fields.htmlField('', body_html, null, {
                        no_label: true,
                        full_width: true,
                    }) }}
                </div>
                {% endif %}
                <div class="tab-pane fade {{ has_html_content ? '' : 'show active' }}" id="text" role="tabpanel" aria-labelledby="text-tab">
                    {% set body_text = item.fields['body_text']|nl2br %}
                    {% if undisclose_body %}
                        {% set body_text = __('The content of the notification contains sensitive information and therefore cannot be displayed.') %}
                    {% endif %}
                    {{ fields.htmlField('', body_text|e, null, {
                        no_label: true,
                        full_width: true,
                    }) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
