<div class="alert alert-{{ type }} {{ important|default(false) ? 'alert-important' : '' }}" role="alert">
   <div class="d-flex">
      <div class="me-2">
         <i class="{{ this.resolvedIcon }} fs-2x alert-icon"></i>
      </div>
      <div>
         {% if title|length %}
            <h4 class="alert-title">
               {{ title }}
            </h4>
         {% endif %}
         {% if messages|length > 0 %}
            <div class="text-muted">
               {% if messages is iterable %}
                  {% for message in messages %}
                     {{ message }}
                     {% if loop.last %}<br />{% endif %}
                  {% endfor %}
               {% else %}
                  {{ messages }}
               {% endif %}
            </div>
         {% endif %}
      </div>
   </div>
</div>
