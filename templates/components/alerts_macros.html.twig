{% macro alert(alert_type = "", title = "", messages = [], icon = "", important = false) %}
   {#{% do call('Toolbox::deprecated', ['Twig alert macros are deprecated. Use the Alert Twig component instead.']) %}#}
   {{ component('Alert', {
      type: alert_type,
      title: title,
      messages: messages,
      icon: icon,
      important: important,
   }) }}
{% endmacro %}

{% macro alert_success(title = "", messages = [], important = false) %}
   {{ _self.alert(
      'success',
      title,
      messages,
      "ti ti-check",
      important
   ) }}
{% endmacro %}

{% macro alert_info(title = "", messages = [], important = false) %}
   {{ _self.alert(
      'info',
      title,
      messages,
      "ti ti-info-circle",
      important
   ) }}
{% endmacro %}

{% macro alert_warning(title = "", messages = [], important = false) %}
   {{ _self.alert(
      'warning',
      title,
      messages,
      "ti ti-alert-triangle",
      important
   ) }}
{% endmacro %}

{% macro alert_danger(title = "", messages = [], important = false) %}
   {{ _self.alert(
      'danger',
      title,
      messages,
      "ti ti-exclamation-circle",
      important
   ) }}
{% endmacro %}
