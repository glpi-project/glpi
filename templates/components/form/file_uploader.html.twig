 # --- Usage ---
 #
 # This partial provides a reusable file uploader dropzone.
 # The JS (FileUploader.js) and SCSS (_file-uploader.scss) are already generic;
 # this Twig layer completes the extraction to make the component fully reusable.
 #
 # To use this partial anywhere in GLPI:
 #
 #   {{ include('components/form/file_uploader.html.twig', {
 #       'input_id': 'my-upload-input',
 #   }, with_context = false) }}
 #
 #   <script type="module">
 #       import { FileUploader } from '{{ js_path("js/modules/FileUploader.js") }}';
 #       new FileUploader(document.getElementById('my-container'));
 #   </script>
 #
 # Full integration with document creation requires an adapter controller
 # (see Document/UploadController.js for the KB example).
 #
 # Parameters:
 #   - input_id      (string)  Unique ID for the file input (default: random)
 #   - input_name    (string)  Name attribute for the input (default: 'files[]')
 #   - multiple      (bool)    Allow multiple files (default: true)
 #   - title         (string)  Dropzone title text
 #   - hint          (string)  Dropzone hint text
 #   - browse_label  (string)  Browse button label
 #}

{% set input_id = input_id ?? 'file-uploader-input-' ~ random() %}
{% set input_name = input_name ?? 'files[]' %}
{% set multiple = multiple ?? true %}
{% set title = title ?? __('Drop files here or click to browse') %}
{% set hint = hint ?? __('PDF, Word, Excel, images and archives are supported') %}
{% set browse_label = browse_label ?? __('Browse Files') %}

<label class="file-uploader-dropzone" for="{{ input_id }}"
       data-glpi-file-uploader-dropzone>
    <input type="file"
           id="{{ input_id }}"
           name="{{ input_name }}"
           {{ multiple ? 'multiple' : '' }}
           class="d-none"
           data-glpi-file-uploader-input>
    <div class="file-uploader-dropzone-content">
        <i class="ti ti-cloud-upload file-uploader-dropzone-icon"></i>
        <p class="file-uploader-dropzone-title">{{ title }}</p>
        <p class="file-uploader-dropzone-hint text-muted">{{ hint }}</p>
        <span class="btn btn-outline-primary btn-sm mt-2">
            <i class="ti ti-folder-open me-1"></i>{{ browse_label }}
        </span>
    </div>
</label>

<div class="file-uploader-preview mt-3 d-none"
     data-glpi-file-uploader-preview>
    <div class="file-uploader-list" role="list"
         data-glpi-file-uploader-list></div>
</div>
