{#
 # KB article auto-save banner.
 #
 # Rendered hidden (d-none). KnowbaseAutosave.js reveals it when a more
 # recent draft is found in localStorage and wires up the Restore button.
 #
 # @since 12.0.0
 #}
<div id="kb-autosave-banner" class="d-none mb-3">
    <span class="alert alert-warning m-0 d-flex align-items-center">
        <i class="ti ti-history d-flex align-items-center justify-content-center flex-shrink-0 me-2"></i>
        <span id="kb-autosave-banner-text">
            {{ __('The backup of this article in your browser is different from the version below.') }}
        </span>
        <span class="ms-auto d-flex gap-2">
            <button type="button" id="kb-autosave-dismiss" class="btn btn-sm btn-ghost-danger">
                {{ __('Dismiss') }}
            </button>
            <button type="button" id="kb-autosave-restore" class="btn btn-sm btn-warning">
                {{ __('Restore') }}
            </button>
        </span>
    </span>
</div>
